# Font
font-family = Fira Code
font-size = 13
font-feature = liga
font-feature = calt

# Theme (gruvbox dark)
theme = Gruvbox Dark Hard

# Window / tabs
gtk-titlebar = true
gtk-titlebar-style = tabs
gtk-toolbar-style = flat
macos-titlebar-style = tabs
window-padding-x = 4
window-padding-y = 4

# Cursor
cursor-style = block
cursor-style-blink = false

# Misc
copy-on-select = clipboard
mouse-hide-while-typing = true
scrollback-limit = 100000

# Split navigation (Dvorak home row: h=left, t=up, n=down, s=right)
keybind = ctrl+h=goto_split:left
keybind = ctrl+t=goto_split:up
keybind = ctrl+n=goto_split:down
keybind = ctrl+s=goto_split:right
