#### General
export VISUAL=nvim
export EDITOR="$VISUAL"
export LANG=en_US.UTF-8  # added to fix zplug command output

# Platform detection
if [[ "$(uname)" == "Darwin" ]]; then
    IS_MAC=true
else
    IS_MAC=false
fi

# PATH - user local bin
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi



#### brew (macOS only)
# shellenv is already evaluated in .zprofile for zsh; this covers bash and any
# case where HOMEBREW_PREFIX isn't set yet.
if $IS_MAC; then
    alias new-brew='eval "$(/opt/homebrew/bin/brew shellenv)"'
    alias old-brew='eval "$(/usr/local/bin/brew shellenv)"'
    [ -z "$HOMEBREW_PREFIX" ] && eval "$(/opt/homebrew/bin/brew shellenv)"
fi


#### mise
if command -v mise &>/dev/null; then
    eval "$(mise activate -s zsh)"
fi


#### Helper functions
# Check if the given command is available for gradual degradation purposes
function command_exists() {
    if ! hash "${1}" &>/dev/null
    then
        return 1
    fi
    return 0
}


rgr() {
    rg $1 --files-with-matches | xargs perl -i -pe"s/$1/$2/g"
}


#### Clipboard helpers (cross-platform)
if $IS_MAC; then
    # pbcopy/pbpaste are native on macOS
    :
else
    if command_exists wl-copy; then
        alias pbcopy='wl-copy'
        alias pbpaste='wl-paste'
    elif command_exists xclip; then
        alias pbcopy='xclip -selection clipboard'
        alias pbpaste='xclip -selection clipboard -o'
    elif command_exists xsel; then
        alias pbcopy='xsel --clipboard --input'
        alias pbpaste='xsel --clipboard --output'
    fi
fi


#### Aliases
alias v="nvim"
alias vim="nvim"
alias g="git"
alias c="clear"
#alias wc="watch --color "
alias mv="mv -i"

# Trash alias (platform-aware)
if $IS_MAC; then
    alias del="mv -t ~/.Trash/"
else
    alias del="gio trash"
    # Rewake internal keyboard if it dies after resume (Lenovo)
    alias kbr='sudo sh -c "echo -n rescan > /sys/devices/platform/i8042/serio0/drvctl"'
fi

alias gbcp="git branch | grep '^\*' | cut -d ' ' -f 2 | tr -d '\n' | pbcopy"
# Rebase onto updated main (taking into account that main upstream may be "main")
alias grbm='gbcp ; git checkout main ; git pull ; git checkout $(pbpaste) ; git rebase main'
alias grbmi='gbcp ; git checkout main ; git pull ; git checkout $(pbpaste) ; git rebase -i main'

# Github copilot
alias gc="gh copilot"
alias gce="gh copilot explain"
alias gcs="gh copilot suggest"

# Use eza as replacement for ls if available
if command_exists eza; then
    alias ls='eza --classify=auto --group-directories-first'
    alias ll='eza -l --classify=auto --group-directories-first'
    alias la='eza -al --classify=auto --group-directories-first'
else
    if [ -x /usr/bin/dircolors ]; then
        test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
        alias ls='ls -F --group-directories-first --color=auto'
        alias ll='ls -lF --group-directories-first --color=auto'
        alias la='ls -AlF --group-directories-first --color=auto'
    else
        alias ls='ls -F --group-directories-first'
        alias ll='ls -lF --group-directories-first'
        alias la='ls -AlF --group-directories-first'
    fi
fi


#### Claude Code account switcher
# Default account is personal; override with CLAUDE_DEFAULT_ACCOUNT=work.
# Explicit: claude-personal, claude-work. Each account uses its own config dir,
# which means MCP servers registered via `claude mcp add` are per-account —
# register Visma MCPs with `claude-work mcp add`, personal ones with `claude`.
# Also exports GH_CONFIG_DIR so `gh` inside the Claude session targets the
# matching account (Claude's Bash tool runs non-interactively and doesn't load
# the gh-* shell functions below).
_claude-run() {
    local account=$1; shift
    local dir=~/.claude
    [ "$account" = work ] && dir=~/.claude-work
    echo "[claude] using ${account} account" >&2
    # CLAUDE_CODE_NO_FLICKER=1 enables alt-screen rendering so the input stays
    # pinned and scrolling doesn't snap to bottom. Upstream's accepted answer
    # for anthropics/claude-code#13591 — also reachable via `/tui fullscreen`.
    CLAUDE_CODE_NO_FLICKER=1 \
        CLAUDE_CONFIG_DIR="$dir" \
        GH_CONFIG_DIR=~/.config/gh-"$account" \
        command claude "$@"
}
claude()          { _claude-run "${CLAUDE_DEFAULT_ACCOUNT:-personal}" "$@"; }
claude-personal() { _claude-run personal "$@"; }
claude-work()     { _claude-run work "$@"; }


#### gh CLI account switcher
# Mirrors the claude switcher: per-process GH_CONFIG_DIR keeps concurrent
# sessions isolated. One-time setup per account:
#   gh-personal auth login
#   gh-work auth login
# Auto-injects --insecure-storage on `auth login`/`auth refresh` so tokens
# land in each dir's hosts.yml. The system keyring is keyed by host only, so
# without per-dir file storage two accounts collide on one keyring entry and
# the last write wins (silent breakage — gh auth status reads the user label
# from hosts.yml, not the actual token). Use `command gh ...` to bypass.
_gh-exec() {
    if [ "$1" = auth ] && { [ "$2" = login ] || [ "$2" = refresh ]; }; then
        case " $* " in
            *' --insecure-storage '*) ;;
            *) set -- "$@" --insecure-storage ;;
        esac
    fi
    command gh "$@"
}
_gh-run() {
    local account=$1; shift
    GH_CONFIG_DIR=~/.config/gh-"$account" _gh-exec "$@"
}
# Bare `gh`: honor an explicitly-set GH_CONFIG_DIR (so claude-* exports and
# `GH_CONFIG_DIR=... gh ...` command-line prefixes win), otherwise pick by
# $GH_DEFAULT_ACCOUNT. The explicit forms below always force their account.
gh() {
    if [ -n "$GH_CONFIG_DIR" ]; then
        _gh-exec "$@"
    else
        _gh-run "${GH_DEFAULT_ACCOUNT:-personal}" "$@"
    fi
}
gh-personal() { _gh-run personal "$@"; }
gh-work()     { _gh-run work "$@"; }


#### Local overrides (not tracked in dotfiles)
[ -f ~/.shellrc.local ] && source ~/.shellrc.local


#### Secrets (not tracked in dotfiles)
[ -f ~/.secrets.env ] && source ~/.secrets.env


#### Visma
[ -f ~/dotfiles/.shellrc-visma ] && source ~/dotfiles/.shellrc-visma
