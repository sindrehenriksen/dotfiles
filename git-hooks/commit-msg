#!/usr/bin/env bash
# Enforce commit message conventions:
# - Title line: warn at 50, error at 72 chars
# - Body: reflow paragraphs at 72 chars (like vim gqip)

msg_file="$1"

# Reflow body paragraphs at 72 chars
# Preserves title (line 1), blank separator (line 2),
# and git comment lines (starting with #).
{
    head -2 "$msg_file"
    tail -n +3 "$msg_file" | grep -v '^#' | fmt -w 72
    tail -n +3 "$msg_file" | grep '^#' || true
} > "${msg_file}.tmp" && mv "${msg_file}.tmp" "$msg_file"

# Validate title length
title=$(head -1 "$msg_file")
if [ ${#title} -gt 72 ]; then
    echo "Commit message lint failed:"
    echo "  - Title is ${#title} chars (max 72): $title"
    exit 1
elif [ ${#title} -gt 50 ]; then
    echo "Commit message warning: title is ${#title} chars (aim for 50)"
fi
