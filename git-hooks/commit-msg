#!/usr/bin/env bash
# Enforce commit message conventions:
# - Title line: error at 50 chars (override: ALLOW_LONG_COMMIT_TITLE=1), hard error at 72
# - Body: reflow paragraphs at 72 chars (like vim gqip)
# - Then delegate to the repo's pre-commit framework commit-msg hooks if present

msg_file="$1"

# Reflow body paragraphs at 72 chars
# Preserves title (line 1), blank separator (line 2),
# and git comment lines (starting with #).
# An awk preprocessor inserts a blank line before each bullet (-/*/+ or
# N.) so fmt sees each bullet as its own paragraph — otherwise fmt joins
# adjacent same-indent bullets into one paragraph and can splice them as
# "- foo. - bar" mid-line. cat -s squeezes the synthetic blanks back.
# The sed filter collapses the double-space that BSD fmt (macOS) inserts
# after sentence-ending punctuation when joining lines.
{
    head -2 "$msg_file"
    tail -n +3 "$msg_file" | grep -v '^#' \
        | awk 'prev != "" && /^[[:space:]]*([-*+]|[0-9]+\.) / { print "" } { print; prev = $0 }' \
        | fmt -w 72 \
        | sed -E 's/([.!?]) {2,}/\1 /g' \
        | cat -s
    tail -n +3 "$msg_file" | grep '^#' || true
} > "${msg_file}.tmp" && mv "${msg_file}.tmp" "$msg_file"

# Validate title length. Strip autosquash prefixes (fixup!/squash!/amend!,
# which can stack) before measuring — git generates them, they're discarded on
# rebase --autosquash, and the underlying subject was already linted on its
# original commit.
title=$(head -1 "$msg_file")
subject="$title"
while [[ "$subject" =~ ^(fixup|squash|amend)!\  ]]; do
    subject="${subject#*! }"
done
if [ ${#subject} -gt 72 ]; then
    echo "Commit message lint failed:"
    echo "  - Title is ${#subject} chars (max 72): $subject"
    exit 1
elif [ ${#subject} -gt 50 ] && [ "${ALLOW_LONG_COMMIT_TITLE:-0}" != "1" ]; then
    echo "Commit message lint failed:"
    echo "  - Title is ${#subject} chars (aim for 50): $subject"
    echo "  - Override with ALLOW_LONG_COMMIT_TITLE=1 (hard cap at 72 still applies)"
    exit 1
fi

# Delegate to repo pre-commit framework for any commit-msg hooks
if [ -f .pre-commit-config.yaml ] && command -v pre-commit &>/dev/null; then
    pre-commit run --hook-stage commit-msg --commit-msg-filename "$msg_file"
fi
