# Visma secrets — copy to ~/.secrets-visma.env and fill in values
# chmod 600 ~/.secrets-visma.env

# Jira (Atlassian MCP server — see setup-visma.sh)
export JIRA_PERSONAL_TOKEN=""

# Confluence — for the curl-based confluence skill, NOT the MCP.
# The Atlassian MCP's Confluence tools are intentionally disabled (auth/VPN
# issues); the skill uses these vars directly. Needs a separate PAT from
# Jira — generate at https://confluence.visma.com/plugins/personalaccesstokens/usertokens.action
export CONFLUENCE_URL="https://confluence.visma.com"
export CONFLUENCE_PERSONAL_TOKEN=""

# Aikido Security MCP server
export AIKIDO_CLIENT_ID=""
export AIKIDO_API_KEY=""

# Visma Connect (flyt common AI)
export VISMA_CONNECT_KEY_STAGE=""
export VISMA_CONNECT_KEY_PROD=""
